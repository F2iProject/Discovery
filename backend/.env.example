# Discovery — Backend Configuration
# Copy this file to .env and adjust values for your environment.

# Database — PostgreSQL (production) or SQLite (local dev)
# For local dev with SQLite:
DATABASE_URL=sqlite:///discovery.db
# For PostgreSQL:
# DATABASE_URL=postgresql://discovery:discovery@localhost:5432/discovery

# Redis (used for caching/sessions — optional for local dev)
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — allowed frontend origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# File uploads
UPLOAD_DIR=uploads
